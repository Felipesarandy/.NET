Class Form1.cs
using System;
using System.Collections.Generic;
using System.Windows.Forms;

namespace ConsultaCliente
{
    public partial class Form1 : Form
    {
        ClienteRepositorio repo = new ClienteRepositorio();

        public Form1()
        {
            InitializeComponent();
        }

        private void Form1_Load(object sender, EventArgs e)
        {
            repo.Adicionar(new Cliente(1, "João"));
            repo.Adicionar(new Cliente(2, "Maria"));
            repo.Adicionar(new Cliente(3, "Carlos"));
            repo.Adicionar(new Cliente(4, "Ana"));

            cbTipoConsulta.Items.Add("Id");
            cbTipoConsulta.Items.Add("Nome");

            cbTipoConsulta.SelectedIndex = 0;
        }

        private void btnListarTodos_Click(object sender, EventArgs e)
        {
            dgvClientes.DataSource = null;
            dgvClientes.DataSource = repo.ListarTodos();
        }

        private void btnPesquisar_Click(object sender, EventArgs e)
        {
            string tipo = cbTipoConsulta.Text;
            string conteudo = txtConteudo.Text;

            if (tipo == "Nome")
            {
                dgvClientes.DataSource = null;
                dgvClientes.DataSource = repo.BuscarPorNome(conteudo);
            }

            if (tipo == "Id")
            {
                int id;

                if (int.TryParse(conteudo, out id))
                {
                    Cliente c = repo.BuscarPorId(id);

                    if (c != null)
                    {
                        dgvClientes.DataSource = null;
                        dgvClientes.DataSource = new List<Cliente> { c };
                    }
                    else
                    {
                        MessageBox.Show("Cliente não encontrado");
                    }
                }
                else
                {
                    MessageBox.Show("Digite um ID válido");
                }
            }
        }

        private void btnCancelar_Click(object sender, EventArgs e)
        {
            this.Close();
        }
    }
}

Class Cliente.cs
using System;

namespace ConsultaCliente
{
    public class Cliente
    {
        public int Id { get; set; }
        public string Nome { get; set; }

        public Cliente(int id, string nome)
        {
            Id = id;
            Nome = nome;
        }

        public override string ToString()
        {
            return Id + " - " + Nome;
        }
    }
}

Class ClienteRepositorio.cs
using System;
using System.Collections.Generic;
using System.Linq;

namespace ConsultaCliente
{
    public class ClienteRepositorio
    {
        public List<Cliente> clientes = new List<Cliente>();

        public void Adicionar(Cliente c)
        {
            clientes.Add(c);
        }

        public List<Cliente> ListarTodos()
        {
            return clientes;
        }

        public List<Cliente> BuscarPorNome(string nome)
        {
            return clientes
                .Where(c => c.Nome.ToLower().Contains(nome.ToLower()))
                .ToList();
        }

        public Cliente BuscarPorId(int id)
        {
            return clientes
                .FirstOrDefault(c => c.Id == id);
        }
    }
}
